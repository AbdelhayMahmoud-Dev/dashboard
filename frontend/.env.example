# ─────────────────────────────────────────────────────────────────────────────
# Frontend environment template. Copy to `.env.local` (dev) or set in Vercel
# project settings (production).
#
# NEXT_PUBLIC_* variables are inlined into the client bundle at build time and
# are NOT secret — anyone with the deployed site can read them. Never put a
# real secret here.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the deployed backend, including version path.
# Dev:  http://localhost:5000/api/v1
# Prod: https://your-backend.onrender.com/api/v1
NEXT_PUBLIC_API_URL=

# Base URL of the backend Socket.IO server (no API version path).
# Dev:  http://localhost:5000
# Prod: https://your-backend.onrender.com
NEXT_PUBLIC_SOCKET_URL=
