# ─────────────────────────────────────────────────────────────────────────────
# Backend environment template. Copy to `.env` and fill in real values.
# Never commit `.env` itself — it's in .gitignore.
#
# Required variables are validated at startup in src/config/env.ts. Missing or
# weak (production) values crash the process with a clear single-line error
# before the server starts listening.
# ─────────────────────────────────────────────────────────────────────────────

# Node runtime mode: development | production | test
NODE_ENV=

# Port the HTTP server binds to. Render injects this — leave empty in cloud env.
PORT=

# ── Database ─────────────────────────────────────────────────────────────────
# Format: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# Local dev: mongodb://localhost:27017/saas-dashboard
MONGODB_URI=

# ── JWT ──────────────────────────────────────────────────────────────────────
# Both secrets must be at least 32 characters and unique to each other.
# Generate with: openssl rand -base64 64
# Production validation rejects values containing "change_me", "dev_", "test_", etc.
JWT_SECRET=
JWT_REFRESH_SECRET=

# Token lifetimes (zeit/ms format: 15m, 1h, 7d). Optional — defaults: 15m / 7d.
JWT_EXPIRE=
JWT_REFRESH_EXPIRE=

# ── CORS / frontend ──────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash).
# Example: https://dashboard.example.com,https://staging.example.com
# Dev: http://localhost:3000
CLIENT_URL=

# ── Cookies ──────────────────────────────────────────────────────────────────
# Used for signed cookie verification.
# Generate with: openssl rand -base64 32
COOKIE_SECRET=

# ── Cache (optional) ─────────────────────────────────────────────────────────
# Leave empty to disable Redis caching. Format: redis://default:<pass>@<host>:<port>
REDIS_URL=

# ── Cloudinary (optional, for product image uploads) ─────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
